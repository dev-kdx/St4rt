{% comment %}
  Product Highlights
  Sección tipo carrusel horizontal con imagen + contenido + CTA.
{% endcomment %}

{{ 'st4rt-product-highlights.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .st4rt-pd--{{ section.id }} {
    --st4rt-pd-title-color: {{ section.settings.title_color }};
    --st4rt-pd-desc-color: {{ section.settings.desc_color }};
    --st4rt-pd-cat-color: {{ section.settings.category_color }};
    --st4rt-pd-title-size-m: {{ section.settings.title_size_m }}px;
    --st4rt-pd-title-size-d: {{ section.settings.title_size_d }}px;
    --st4rt-pd-desc-size-m: {{ section.settings.desc_size_m }}px;
    --st4rt-pd-desc-size-d: {{ section.settings.desc_size_d }}px;
    --st4rt-pd-cat-size-m: {{ section.settings.category_size_m }}px;
    --st4rt-pd-cat-size-d: {{ section.settings.category_size_d }}px;
    --st4rt-pd-title-weight: {{ section.settings.title_weight }};
    --st4rt-pd-font-family: {% if section.settings.font_family == "bebas" %}"Bebas Neue", system-ui, -apple-system, "Segoe UI", Roboto, Arial{% else %}system-ui, -apple-system, "Segoe UI", Roboto, Arial{% endif %};
    --st4rt-pd-card-radius: {{ section.settings.radius }}px;
    --st4rt-pd-gap: {{ section.settings.gap }}px;
  }
{%- endstyle -%}

<section
  class="st4rt-pd st4rt-pd--{{ section.id }}"
  data-st4rt-pd
  aria-label="{{ section.settings.aria_label | escape }}"
>
  <div class="st4rt-pd__wrap">
    {% if section.settings.heading != blank %}
      <header class="st4rt-pd__header">
        <h2 class="st4rt-pd__heading">{{ section.settings.heading }}</h2>
        {% if section.settings.subheading != blank %}
          <p class="st4rt-pd__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </header>
    {% endif %}

    <div class="st4rt-pd__viewport" data-st4rt-pd-viewport tabindex="0" aria-label="Slides">
      <div class="st4rt-pd__track" data-st4rt-pd-track>
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'detail_slide' %}
              {% assign img = block.settings.image %}
              <article class="st4rt-pd__slide" data-st4rt-pd-slide {{ block.shopify_attributes }}>
                <div class="st4rt-pd__card">
                  <div class="st4rt-pd__content">
                    {% if block.settings.category != blank %}
                      <p class="st4rt-pd__category">{{ block.settings.category }}</p>
                    {% endif %}

                    {% if block.settings.title != blank %}
                      <h3 class="st4rt-pd__title">{{ block.settings.title }}</h3>
                    {% endif %}

                    {% if block.settings.description != blank %}
                      <div class="st4rt-pd__desc rte">{{ block.settings.description }}</div>
                    {% endif %}

                    {% if block.settings.buy_liquid != blank %}
                      <div class="st4rt-pd__buy">{{ block.settings.buy_liquid }}</div>
                    {% endif %}

                    {% if section.settings.show_copy_file %}
                      <button
                        type="button"
                        class="st4rt-pd__copy-btn"
                        data-st4rt-pd-copy
                        data-copy-value="{{ block.settings.copy_file_value | default: block.settings.title | escape }}"
                      >
                        {{ section.settings.copy_file_label }}
                      </button>
                    {% endif %}
                  </div>

                  <div class="st4rt-pd__media">
                    {% if img != blank %}
                      <img
                        class="st4rt-pd__img"
                        src="{{ img | image_url: width: 900 }}"
                        srcset="
                          {{ img | image_url: width: 450 }} 450w,
                          {{ img | image_url: width: 700 }} 700w,
                          {{ img | image_url: width: 900 }} 900w,
                          {{ img | image_url: width: 1200 }} 1200w
                        "
                        sizes="(max-width: 749px) 90vw, 45vw"
                        width="{{ img.width }}"
                        height="{{ img.height }}"
                        loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                        decoding="async"
                        fetchpriority="{% if forloop.first %}high{% else %}auto{% endif %}"
                        alt="{{ img.alt | default: block.settings.title | escape }}"
                      >
                    {% else %}
                      <div class="st4rt-pd__img-placeholder" aria-hidden="true"></div>
                    {% endif %}
                  </div>
                </div>
              </article>

            {% when '@app' %}
              {% render block %}
          {% endcase %}
        {% endfor %}
      </div>
    </div>

    {% if section.settings.show_nav and section.blocks.size > 1 %}
      <div class="st4rt-pd__nav">
        <button type="button" class="st4rt-pd__btn" data-st4rt-pd-prev aria-label="Previous slide">‹</button>
        <button type="button" class="st4rt-pd__btn" data-st4rt-pd-next aria-label="Next slide">›</button>
      </div>
    {% endif %}
  </div>

  <script src="{{ 'st4rt-product-highlights.js' | asset_url }}" defer></script>
</section>

{% schema %}
{
  "name": "Product Highlights",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "aria_label", "label": "Aria label", "default": "Product Highlights section" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Product Highlights" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Discover what makes this product different." },
    { "type": "checkbox", "id": "show_nav", "label": "Show nav", "default": false },
    { "type": "checkbox", "id": "show_copy_file", "label": "Show copy file button", "default": true },
    { "type": "text", "id": "copy_file_label", "label": "Copy file button label", "default": "Copiar archivo" },

    {
      "type": "select",
      "id": "font_family",
      "label": "Font family",
      "default": "bebas",
      "options": [
        { "value": "bebas", "label": "Bebas Neue" },
        { "value": "system", "label": "System" }
      ]
    },

    { "type": "color", "id": "title_color", "label": "Title color", "default": "#FFFFFF" },
    { "type": "color", "id": "desc_color", "label": "Description color", "default": "#EAEAEA" },
    { "type": "color", "id": "category_color", "label": "Category color", "default": "#BFBFBF" },

    { "type": "range", "id": "title_size_m", "label": "Title size mobile", "min": 18, "max": 46, "step": 1, "default": 30 },
    { "type": "range", "id": "title_size_d", "label": "Title size desktop", "min": 20, "max": 64, "step": 1, "default": 42 },
    { "type": "range", "id": "desc_size_m", "label": "Description size mobile", "min": 12, "max": 22, "step": 1, "default": 14 },
    { "type": "range", "id": "desc_size_d", "label": "Description size desktop", "min": 12, "max": 24, "step": 1, "default": 16 },
    { "type": "range", "id": "category_size_m", "label": "Category size mobile", "min": 10, "max": 20, "step": 1, "default": 12 },
    { "type": "range", "id": "category_size_d", "label": "Category size desktop", "min": 10, "max": 22, "step": 1, "default": 13 },

    {
      "type": "select",
      "id": "title_weight",
      "label": "Title weight",
      "default": "700",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra bold" }
      ]
    },

    { "type": "range", "id": "gap", "label": "Gap", "min": 8, "max": 40, "step": 1, "default": 16 },
    { "type": "range", "id": "radius", "label": "Radius", "min": 0, "max": 28, "step": 1, "default": 18 }
  ],
  "blocks": [
    {
      "type": "detail_slide",
      "name": "Highlight",
      "settings": [
        { "type": "text", "id": "category", "label": "Category", "default": "Category" },
        { "type": "text", "id": "title", "label": "Title", "default": "Highlight title" },
        { "type": "richtext", "id": "description", "label": "Description", "default": "<p>Short highlight description.</p>" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "liquid", "id": "buy_liquid", "label": "Buy liquid", "default": "Buy liquid" },
        { "type": "text", "id": "copy_file_value", "label": "Copy file value", "default": "Copy file" }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Product Highlights",
      "blocks": [{ "type": "detail_slide" }]
    }
  ]
}
{% endschema %}