        { "type": "range", "id": "pad_d", "label": "Padding desktop", "min": 0, "max": 90, "step": 2, "unit": "px", "default": 24 },
        { "type": "range", "id": "pad_m", "label": "Padding mobile", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 18 }
