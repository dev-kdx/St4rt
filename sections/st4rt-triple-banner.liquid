        { "type": "text", "id": "button_text", "label": "texto botón", "default": "AGREGA EL TEXTO DEL BOTÓN" },
        { "type": "url", "id": "button_url", "label": "url botón" },

        { "type": "header", "content": "estilo texto" },
        { "type": "color", "id": "kicker_color", "label": "Color kicker", "default": "#FFFFFF" },
        { "type": "color", "id": "title_color", "label": "Color título", "default": "#FFFFFF" },
        { "type": "color", "id": "subtitle_color", "label": "Color subtítulo", "default": "#FFFFFF" },

        { "type": "range", "id": "kicker_size", "label": "Kicker tamaño", "min": 10, "max": 22, "step": 1, "unit": "px", "default": 12 },
        { "type": "range", "id": "title_size_d", "label": "Título tamaño desktop", "min": 18, "max": 92, "step": 1, "unit": "px", "default": 42 },
        { "type": "range", "id": "title_size_m", "label": "Título tamaño mobile", "min": 16, "max": 64, "step": 1, "unit": "px", "default": 34 },
        { "type": "range", "id": "subtitle_size", "label": "Subtítulo tamaño", "min": 12, "max": 26, "step": 1, "unit": "px", "default": 16 },

        { "type": "select", "id": "halign", "label": "Alineación horizontal", "default": "center", "options": [
          { "value": "left", "label": "Izquierda" },
          { "value": "center", "label": "Centro" },
          { "value": "right", "label": "Derecha" }
        ]},
        { "type": "select", "id": "valign", "label": "Alineación vertical", "default": "center", "options": [
          { "value": "top", "label": "Arriba" },
          { "value": "center", "label": "Centro" },
          { "value": "bottom", "label": "Abajo" }
